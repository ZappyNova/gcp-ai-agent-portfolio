# Environment variables (copy to .env and fill in)
# Add .env to .gitignore — never commit real secrets!

# ── LLM / Agent ──
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/deepseek/deepseek-v4-flash

# ── Discord ──
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_GARDEN=your_garden_channel_id_here
DISCORD_CHANNEL_WEATHER=your_weather_channel_id_here

# ── Weather Station ──
TEMPEST_STATION_ID=tempest_station_id_here
TEMPEST_API_TOKEN=your_tempest_api_token_here

# ── Email ──
PROTON_EMAIL=your_email@proton.me
PROTON_PASSWORD=your_proton_password_here